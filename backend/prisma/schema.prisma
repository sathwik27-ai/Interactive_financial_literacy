// This is your Prisma schema file for the Interactive Financial Literacy Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  expenses      Expense[]
  budgets       Budget[]
  goals         Goal[]
  groupMembers  GroupMember[]
  quizzes       QuizHistory[]
  chatHistory   ChatMessage[]
  scamLogs      ScamLog[]
  
  @@index([email])
}

model Expense {
  id          String   @id @default(uuid())
  userId      String
  category    String
  amount      Float
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, date])
  @@index([userId, category])
}

model Budget {
  id          String   @id @default(uuid())
  userId      String
  category    String
  amount      Float
  startDate   DateTime @default(now())
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model Goal {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  targetAmount Float
  currentAmount Float  @default(0)
  targetDate  DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model GroupExpense {
  id          String   @id @default(uuid())
  title       String
  description String?
  totalAmount Float
  paidBy      String // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  members     GroupMember[]
  
  @@index([paidBy])
}

model GroupMember {
  id             String       @id @default(uuid())
  userId         String
  groupExpenseId String
  share          Float
  isPaid         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupExpense   GroupExpense @relation(fields: [groupExpenseId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([groupExpenseId])
}

model QuizHistory {
  id          String   @id @default(uuid())
  userId      String
  topic       String
  score       Int
  totalQuestions Int
  answers     String   // JSON string storing answers
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String   // 'user' or 'assistant'
  content   String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
}

model ScamLog {
  id          String   @id @default(uuid())
  userId      String
  message     String   // The suspicious message analyzed
  category    String?  // Type of scam detected
  confidence  Float    // AI confidence score
  explanation String?  // AI's explanation
  isScam      Boolean  // Final verdict
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 'budget_warning', 'goal_milestone', etc.
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([userId, isRead])
}